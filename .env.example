# Без слэша в конце. Нужен для абсолютных og:url / og:image в собранном index.html и для Seo.tsx.
# На Vercel: Project → Settings → Environment Variables → VITE_SITE_URL = https://<твой-домен>.vercel.app
# Без этого в build подставится your-domain.com и превью в Telegram не сработают.
VITE_SITE_URL=https://your-domain.com
